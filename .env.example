# .env.example for FITNESS App (do not use real secrets in this file!)

# The base URL for your frontend - must not include username/password, just the public URL.
APP_BASE_URL=https://levelfitcoach.com

# Google OAuth (replace in Railway with your actual client id/secret)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secrets (set these in Railway with secure random values)
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# Example database URL (use a valid value in Railway, do not check real passwords into git)
DATABASE_URL=your-database-url
